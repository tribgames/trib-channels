{
  "description": "claude2bot plugin hooks — session-start + permission only",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.cjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require('fs').writeFileSync(require('path').join(require('os').tmpdir(),'claude2bot-turn-end'),String(Date.now()))\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/permission-request.cjs",
            "timeout": 900000
          }
        ]
      }
    ]
  }
}
